# ============================================================
# WP Content Autopilot — Environment Variables (.env.example)
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# ── APP CONFIG ──────────────────────────────────────────────────
APP_ENV=local
SITE_BASE_URL=http://localhost:8080
SERVICE_BASE_URL=http://127.0.0.1:3100
SERVICE_PORT=3100

# ── WORDPRESS AUTH ──────────────────────────────────────────────
# Create an Application Password in WP Admin → Users → Your Profile
WP_BASE_URL=http://localhost:8080
WP_API_USER=automation_user
WP_APPLICATION_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── AI PROVIDER KEYS ───────────────────────────────────────────
# Set at least ONE provider key. Both are supported simultaneously.
OPENAI_API_KEY=sk-REPLACE_ME
GEMINI_API_KEY=AIza-REPLACE_ME

# Legacy fallback (optional): fills whichever per-provider key is missing
AI_PROVIDER=gemini
AI_API_KEY=REPLACE_ME

# ── MULTI-MODEL PER STAGE ──────────────────────────────────────
# Research stage (uses grounding when provider=gemini)
LLM_RESEARCH_PROVIDER=gemini
LLM_RESEARCH_MODEL=gemini-2.0-flash
LLM_RESEARCH_GROUNDING=google_search

# Draft — fast model for writing
LLM_DRAFT_PROVIDER=gemini
LLM_DRAFT_MODEL=gemini-2.0-flash

# Final edit — high-quality model for polish
LLM_FINAL_PROVIDER=gemini
LLM_FINAL_MODEL=gemini-2.0-flash

# Image generation
LLM_IMAGE_PROVIDER=gemini
LLM_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
LLM_IMAGE_REQUIRED=false

# ── GEMINI SDK MODE ─────────────────────────────────────────────
GEMINI_API_MODE=genai_sdk

# ── PIPELINE CONFIG ─────────────────────────────────────────────
DAILY_JOB_QUOTA=1
LOG_LEVEL=info

# ── PUBLISH POSTURE ─────────────────────────────────────────────
# auto_publish — publishes when QA gates pass
# always_draft — creates WP drafts only (safe for review)
PUBLISH_POSTURE=always_draft

# ── CRON / SCHEDULER ───────────────────────────────────────────
CRON_ENABLED=false
CRON_SCHEDULE=0 6 * * *
CRON_TIMEZONE=UTC

# ── PROMPT FILE ─────────────────────────────────────────────────
# Path to your custom prompts file (default: ./prompts/my_prompts.md)
PROMPTS_FILE_PATH=./prompts/my_prompts.md

# ── LOCAL DB ────────────────────────────────────────────────────
LOCAL_DB_ENABLED=true
DB_PATH=./data/pipeline.db

# ── KEYWORD CSV ─────────────────────────────────────────────────
KEYWORD_CSV_PATH=./data/keyword.csv

# ── THROUGHPUT & COST CONTROL ───────────────────────────────────
PIPELINE_MAX_CONCURRENT_RUNS=1
PIPELINE_MAX_JOBS_PER_TICK=1
PIPELINE_DAILY_COST_CAP_USD=5
PIPELINE_PER_JOB_COST_CAP_USD=1
PIPELINE_MAX_RETRY_ATTEMPTS=3
PIPELINE_RETRY_BACKOFF_MS=2000

# ── RANK MATH SEO KEYS (discovered per site) ───────────────────
# Discover via: WP Admin → Rank Math → check meta key names
RANKMATH_KEY_TITLE=
RANKMATH_KEY_DESCRIPTION=
RANKMATH_KEY_FOCUS_KEYWORD=
RANKMATH_KEY_ROBOTS=
RANKMATH_KEY_CANONICAL=
RANKMATH_KEY_SCHEMA_TYPE=

# ── INTERNAL LINKS ──────────────────────────────────────────────
INTERNAL_LINKS_ENABLED=false

# ── NEWS INGEST (optional) ──────────────────────────────────────
NEWS_ENABLED=false
NEWS_FEEDS=
NEWS_LOOKBACK_HOURS=24
NEWS_MAX_ITEMS_PER_TICK=3
NEWS_HTTP_TIMEOUT_MS=5000

# ── CONTENT DEFAULTS ────────────────────────────────────────────
# ISO language code for content generation (e.g. 'en', 'vi', 'es')
DEFAULT_LANGUAGE=en
